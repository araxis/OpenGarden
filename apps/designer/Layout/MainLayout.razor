@inherits LayoutComponentBase
@inject IJSRuntime JS

<MudThemeProvider Theme="_theme" IsDarkMode="_isDarkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="0" Dense="true" Class="designer-appbar">
        <MudIcon Icon="@Icons.Material.Filled.LocalFlorist" />
        <MudText Typo="Typo.h6" Class="ml-2">OpenGarden Designer</MudText>
        <MudSpacer />
        <MudSelect Text="@GetThemeModeName(_themeMode)" T="ThemeMode" Variant="Variant.Outlined" Value="_themeMode" ValueChanged="SetThemeMode" Dense="true" FitContent="true" Margin="Margin.Dense" aria-label="Theme mode">
            <MudSelectItem T="ThemeMode" Value="ThemeMode.System"><div class="d-flex align-center"><MudIcon Icon="@Icons.Material.Filled.Computer" Class="mr-2" /><span>System</span></div></MudSelectItem>
            <MudSelectItem T="ThemeMode" Value="ThemeMode.Light"><div class="d-flex align-center"><MudIcon Icon="@Icons.Material.Filled.WbSunny" Class="mr-2" /><span>Light</span></div></MudSelectItem>
            <MudSelectItem T="ThemeMode" Value="ThemeMode.Dark"><div class="d-flex align-center"><MudIcon Icon="@Icons.Material.Filled.Nightlight" Class="mr-2" /><span>Dark</span></div></MudSelectItem>
        </MudSelect>
    </MudAppBar>

    <MudMainContent Class="designer-shell">
        @Body
    </MudMainContent>
</MudLayout>

@code {
    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#2f6f5e",
            Secondary = "#365b8c",
            Tertiary = "#b58b2a",
            AppbarBackground = "#f7faf8",
            AppbarText = "#17251f",
            Background = "#f4f7f5",
            Surface = "#ffffff",
            DrawerBackground = "#ffffff",
            TextPrimary = "#17251f",
            TextSecondary = "#5c6c64"
        },
        PaletteDark = new PaletteDark
        {
            Primary = "#75bda8",
            Secondary = "#89a9d8",
            Tertiary = "#d4b15f",
            AppbarBackground = "#121a17",
            AppbarText = "#eaf2ee",
            Background = "#0f1513",
            Surface = "#19231f",
            DrawerBackground = "#19231f",
            TextPrimary = "#eaf2ee",
            TextSecondary = "#a8b9b1"
        },
        LayoutProperties = new LayoutProperties
        {
            DefaultBorderRadius = "8px"
        }
    };

    private ThemeMode _themeMode = ThemeMode.System;
    private bool _isDarkMode;
    private bool _systemPrefersDark;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        _systemPrefersDark = await JS.InvokeAsync<bool>("openGardenDesigner.prefersDarkMode");
        ApplyThemeMode();
        StateHasChanged();
    }

    private void SetThemeMode(ThemeMode mode)
    {
        _themeMode = mode;
        ApplyThemeMode();
    }

    private void ApplyThemeMode()
    {
        _isDarkMode = _themeMode switch
        {
            ThemeMode.Dark => true,
            ThemeMode.Light => false,
            _ => _systemPrefersDark
        };
    }

    private string? GetThemeModeName(ThemeMode themeMode)
    {
        return themeMode switch
        {
            ThemeMode.System => "System",
            ThemeMode.Light => "Light",
            ThemeMode.Dark => "Dark",
            _ => null
        };
    }

}
