@page "/"
@inject IJSRuntime JS

<PageTitle>OpenGarden Designer</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="designer-page">
    <MudGrid Spacing="3">
        <MudItem xs="12" lg="8">
            <MudStack Spacing="3">
                <DesignerHeader CopyRequested="CopyConfig" />

                <MudGrid Spacing="3">
                    <MudItem xs="12" md="6">
                        <OutputPanel State="_state" OnChanged="Refresh" />
                    </MudItem>

                    <MudItem xs="12" md="6">
                        <PotSizePanel State="_state" OnChanged="Refresh" />
                    </MudItem>

                    <MudItem xs="12" md="6">
                        <WallsAndHolesPanel State="_state" OnChanged="Refresh" />
                    </MudItem>

                    <MudItem xs="12" md="6">
                        <InsertGridPanel State="_state" OnChanged="Refresh" />
                    </MudItem>
                </MudGrid>
            </MudStack>
        </MudItem>

        <MudItem xs="12" lg="4">
            <MudStack Spacing="3">
                <PreviewPanel State="_state" />
                <GeneratedScadPanel State="_state" />
            </MudStack>
        </MudItem>
    </MudGrid>
</MudContainer>

@code {
    private readonly DesignerState _state = new();

    private async Task CopyConfig()
    {
        await JS.InvokeAsync<bool>("openGardenDesigner.copyText", _state.GenerateScadConfig());
    }

    private void Refresh()
    {
        StateHasChanged();
    }
}
