<MudPaper Class="section-panel" Elevation="0">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-2">
        <MudText Typo="Typo.subtitle1" Class="panel-title" Style="margin:0">Cell Features</MudText>
        <MudIconButton Icon="@Icons.Material.Filled.Add" Color="Color.Primary" OnClick="AddFeature" title="Add cell feature" />
    </MudStack>
    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-3">
        Configure each grid cell's features. Later entries override earlier entries when they target the same cell and plane.
    </MudText>

    <MudExpansionPanels MultiExpansion="true" Elevation="0">
        @for (var i = 0; i < State.CellFeatures.Count; i++)
        {
            var index = i;
            var feature = State.CellFeatures[index];

            <MudExpansionPanel Text="@PanelTitle(feature)">
                <CellFeatureEditor
                    Feature="feature"
                    RowCount="RowCount"
                    ColumnCount="ColumnCount"
                    OnChanged="OnChanged"
                    OnRemove="RemoveFeature"
                    CanMoveUp="@(index > 0)"
                    CanMoveDown="@(index < State.CellFeatures.Count - 1)"
                    OnMoveUp="(() => MoveFeature(index, index - 1))"
                    OnMoveDown="(() => MoveFeature(index, index + 1))"
                />
            </MudExpansionPanel>
        }
    </MudExpansionPanels>
</MudPaper>

@code {
    [Parameter, EditorRequired]
    public DesignerState State { get; set; } = new();

    [Parameter]
    public EventCallback OnChanged { get; set; }

    private int RowCount => DesignerState.TrackCount(State.GridRows);
    private int ColumnCount => DesignerState.TrackCount(State.GridColumns);

    private async Task AddFeature()
    {
        State.CellFeatures.Add(new CellFeatureConfig
        {
            Row = Math.Clamp(State.CellFeatures.Count + 1, 1, Math.Max(1, RowCount)),
            Column = 1
        });
        await OnChanged.InvokeAsync();
    }

    private async Task RemoveFeature(CellFeatureConfig feature)
    {
        State.CellFeatures.Remove(feature);
        if (State.CellFeatures.Count == 0)
            State.CellFeatures.Add(new CellFeatureConfig());

        await OnChanged.InvokeAsync();
    }

    private async Task MoveFeature(int fromIndex, int toIndex)
    {
        if (fromIndex < 0 || fromIndex >= State.CellFeatures.Count)
            return;
        if (toIndex < 0 || toIndex >= State.CellFeatures.Count)
            return;
        if (fromIndex == toIndex)
            return;

        (State.CellFeatures[fromIndex], State.CellFeatures[toIndex]) = (State.CellFeatures[toIndex], State.CellFeatures[fromIndex]);
        await OnChanged.InvokeAsync();
    }

    private static string PanelTitle(CellFeatureConfig feature) =>
        $"Row {feature.Row}, Col {feature.Column}: {Label(feature.Feature)}";

    private static string Label(string feature) => feature switch
    {
        FeatureTypes.DrainHoles => "Drain holes",
        FeatureTypes.LidLip     => "Lid lip",
        FeatureTypes.WickPort   => "Wick port",
        FeatureTypes.FillTube   => "Fill tube",
        FeatureTypes.Box        => "Box",
        _                       => feature
    };
}
