<MudPaper Class="section-panel" Elevation="0">
    <MudText Typo="Typo.subtitle1" Class="panel-title">Walls and Holes</MudText>
    <MudNumericField T="double" Label="Seat Height" Min="1" Max="5" Step="0.5" @bind-Value="State.SeatHeight" @bind-Value:after="NotifyChanged" Adornment="Adornment.End" AdornmentText="mm" />
    <MudNumericField T="double" Label="Wall Thickness" Min="1" Max="8" Step="0.25" @bind-Value="State.WallThickness" @bind-Value:after="NotifyChanged" Adornment="Adornment.End" AdornmentText="mm" />
    <MudNumericField T="double" Label="Base Thickness" Min="1" Max="8" Step="0.25" @bind-Value="State.BaseThickness" @bind-Value:after="NotifyChanged" Adornment="Adornment.End" AdornmentText="mm" />
</MudPaper>

@code {
    [Parameter, EditorRequired]
    public DesignerState State { get; set; } = new();

    [Parameter]
    public EventCallback OnChanged { get; set; }

    private Task NotifyChanged() => OnChanged.InvokeAsync();
}
