<MudPaper Class="feature-panel" Elevation="0">
    <MudText Typo="Typo.subtitle2">Fill Tube</MudText>
    <MudSlider T="double" Min="0" Max="5" Step="0.1" @bind-Value="Feature.Clearance" @bind-Value:after="NotifyChanged" Color="Color.Primary">Wall clearance: @(Feature.Clearance.ToString("0.#")) mm</MudSlider>
</MudPaper>

@code {
    [Parameter, EditorRequired]
    public FillTubeFeature Feature { get; set; } = new();

    [Parameter]
    public EventCallback OnChanged { get; set; }

    private Task NotifyChanged() => OnChanged.InvokeAsync();
}
