<MudPaper Class="feature-panel" Elevation="0">
    <MudText Typo="Typo.subtitle2">Drain Holes</MudText>
    <MudSelect T="string" Label="Pattern" Dense="true" @bind-Value="Feature.Pattern" @bind-Value:after="NotifyChanged">
        <MudSelectItem T="string" Value="@("Rectangle")">Rectangle grid</MudSelectItem>
        <MudSelectItem T="string" Value="@("Circle")">Circular cluster</MudSelectItem>
    </MudSelect>
    <MudGrid Spacing="2">
        <MudItem xs="6">
            <MudNumericField T="int" Label="Rows" Min="1" Max="10" @bind-Value="Feature.Rows" @bind-Value:after="NotifyChanged" />
        </MudItem>
        <MudItem xs="6">
            <MudNumericField T="int" Label="Columns" Min="1" Max="10" @bind-Value="Feature.Columns" @bind-Value:after="NotifyChanged" />
        </MudItem>
    </MudGrid>
    <MudNumericField T="double" Label="Diameter" Min="1" Max="15" Step="0.5" @bind-Value="Feature.Diameter" @bind-Value:after="NotifyChanged" Adornment="Adornment.End" AdornmentText="mm" />
    <MudNumericField T="double" Label="Area Padding" Min="0" Max="80" Step="0.5" @bind-Value="Feature.Padding" @bind-Value:after="NotifyChanged" Adornment="Adornment.End" AdornmentText="mm" />
</MudPaper>

@code {
    [Parameter, EditorRequired]
    public DrainHoleFeature Feature { get; set; } = new();

    [Parameter]
    public EventCallback OnChanged { get; set; }

    private Task NotifyChanged() => OnChanged.InvokeAsync();
}
