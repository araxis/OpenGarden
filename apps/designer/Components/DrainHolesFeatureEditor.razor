<MudPaper Class="feature-panel" Elevation="0">
    <MudText Typo="Typo.subtitle2">Drain Holes</MudText>
    <MudSelect T="string" Label="Pattern" Dense="true" @bind-Value="Feature.Pattern" @bind-Value:after="NotifyChanged">
        <MudSelectItem T="string" Value="@("Rectangle")">Rectangle grid</MudSelectItem>
        <MudSelectItem T="string" Value="@("Circle")">Circular cluster</MudSelectItem>
    </MudSelect>
    <MudSlider T="int" Min="1" Max="10" @bind-Value="Feature.Rows" @bind-Value:after="NotifyChanged" Color="Color.Primary">Rows: @Feature.Rows</MudSlider>
    <MudSlider T="int" Min="1" Max="10" @bind-Value="Feature.Columns" @bind-Value:after="NotifyChanged" Color="Color.Primary">Columns: @Feature.Columns</MudSlider>
    <MudSlider T="double" Min="1" Max="15" Step="0.5" @bind-Value="Feature.Diameter" @bind-Value:after="NotifyChanged" Color="Color.Primary">Diameter: @(Feature.Diameter.ToString("0.#")) mm</MudSlider>
    <MudSlider T="double" Min="0" Max="80" Step="0.5" @bind-Value="Feature.Padding" @bind-Value:after="NotifyChanged" Color="Color.Primary">Area padding: @(Feature.Padding.ToString("0.#")) mm</MudSlider>
</MudPaper>

@code {
    [Parameter, EditorRequired]
    public DrainHoleFeature Feature { get; set; } = new();

    [Parameter]
    public EventCallback OnChanged { get; set; }

    private Task NotifyChanged() => OnChanged.InvokeAsync();
}
