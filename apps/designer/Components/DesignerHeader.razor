<MudPaper Class="section-panel" Elevation="0">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="section-heading">
        <div>
            <MudText Typo="Typo.h5">Pot Designer</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">OpenGarden print configuration</MudText>
        </div>
        <MudButtonGroup Color="Color.Primary" Variant="Variant.Filled">
            <MudButton StartIcon="@Icons.Material.Filled.ContentCopy" OnClick="CopyRequested">Copy Config</MudButton>
            <MudButton StartIcon="@Icons.Material.Filled.ViewInAr">Render</MudButton>
        </MudButtonGroup>
    </MudStack>
</MudPaper>

@code {
    [Parameter]
    public EventCallback CopyRequested { get; set; }
}
